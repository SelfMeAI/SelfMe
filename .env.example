# SelfMe TS Gateway 配置

# Gateway 监听地址
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# 协议选择
LLM_PROTOCOL=openai

# 通用 LLM 配置
# 当 LLM_PROTOCOL=openai 时，填写 OpenAI 兼容地址与模型。
# 当 LLM_PROTOCOL=anthropic 时，填写 Anthropic 协议地址与模型。
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
