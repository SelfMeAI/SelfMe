{
  "name": "@selfme/desktop",
  "version": "2026.4.21",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:main": "pnpm exec tsc -p tsconfig.node.json && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 pnpm exec electron dist-electron/main.js",
    "build": "vite build && tsc -p tsconfig.node.json",
    "start": "pnpm exec electron dist-electron/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@selfme/chat-ui": "workspace:*",
    "@selfme/protocol": "workspace:*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^40.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
